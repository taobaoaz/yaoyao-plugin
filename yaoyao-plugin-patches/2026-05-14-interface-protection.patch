@@ -0,0 +1,136 @@
+/**
+ * core/tag/tag.ts — Pure tag logic, zero platform awareness.
+ */
+
+import type { UnifiedDB } from "../../platform/db/types.js";
+
+export interface TagSearchResult {
+  memory_id: number;
+  tag: string;
+  user_text: string;
+  asst_text: string;
+  date: string;
+}
+
+export interface PopularTag {
+  tag: string;
+  count: number;
+}
+
+export function ensureTagTable(db: UnifiedDB): void {
+  if (!db) throw new TypeError("ensureTagTable: db is required");
+  db.exec(
+    "CREATE TABLE IF NOT EXISTS memory_tags (" +
+      "id INTEGER PRIMARY KEY AUTOINCREMENT, " +
+      "memory_id INTEGER NOT NULL, " +
+      "tag TEXT NOT NULL COLLATE NOCASE, " +
+      "created_at TEXT DEFAULT (datetime('now'))" +
+    ")"
+  );
+  db.exec("CREATE INDEX IF NOT EXISTS idx_tags_tag ON memory_tags(tag)");
+  db.exec("CREATE INDEX IF NOT EXISTS idx_tags_memory ON memory_tags(memory_id)");
+}
+
+export function addTagsToQuery(
+  db: UnifiedDB,
+  query: string,
+  tags: string[],
+  limit: number
+): { matched: number; added: number } {
+  if (!db) throw new TypeError("addTagsToQuery: db is required");
+  if (typeof query !== "string") throw new TypeError("addTagsToQuery: query must be a string");
+  if (!Array.isArray(tags)) throw new TypeError("addTagsToQuery: tags must be an array");
+  if (!Number.isFinite(limit) || limit < 1) limit = 10;
+  const ftsStmt = db.prepare(
+    "SELECT id FROM memory_meta WHERE user_text LIKE ? ESCAPE '\\' OR asst_text LIKE ? ESCAPE '\\' LIMIT ?"
+  );
+  const safeQ = query.slice(0, 200).replace(/%/g, "\\%").replace(/_/g, "\\_");
+  const likeQ = `%${safeQ}%`;
+  const rows = ftsStmt.all(likeQ, likeQ, limit) as Array<{ id: number }>;
+  if (rows.length === 0) return { matched: 0, added: 0 };
+
+  const insertTag = db.prepare("INSERT OR IGNORE INTO memory_tags (memory_id, tag) VALUES (?, ?)");
+  let added = 0;
+  db.exec("BEGIN");
+  for (const row of rows) {
+    for (const tag of tags) {
+      try {
+        insertTag.run(row.id, tag.trim());
+        added++;
+      } catch { /* ignore duplicates */ }
+    }
+  }
+  db.exec("COMMIT");
+  return { matched: rows.length, added };
+}
+
+export function removeTags(db: UnifiedDB, tags: string[]): number {
+  if (!db) throw new TypeError("removeTags: db is required");
+  if (!Array.isArray(tags)) throw new TypeError("removeTags: tags must be an array");
+  const delStmt = db.prepare("DELETE FROM memory_tags WHERE tag = ?");
+  let removed = 0;
+  db.exec("BEGIN");
+  for (const tag of tags) {
+    const info = delStmt.run(tag.trim());
+    removed += Number(info.changes);
+  }
+  db.exec("COMMIT");
+  return removed;
+}
+
+export function removeAllTags(db: UnifiedDB): number {
+  if (!db) throw new TypeError("removeAllTags: db is required");
+  const count = db.prepare("SELECT COUNT(*) as c FROM memory_tags").get() as any;
+  db.exec("BEGIN");
+  db.exec("DELETE FROM memory_tags");
+  db.exec("COMMIT");
+  return count?.c ?? 0;
+}
+
+export function cleanOrphanTags(db: UnifiedDB): number {
+  if (!db) throw new TypeError("cleanOrphanTags: db is required");
+  const del = db.prepare(
+    "DELETE FROM memory_tags WHERE NOT EXISTS (SELECT 1 FROM memory_meta WHERE memory_meta.id = memory_tags.memory_id)"
+  );
+  const info = del.run();
+  return Number(info.changes);
+}
+
+export function getPopularTags(db: UnifiedDB, limit: number): PopularTag[] {
+  if (!db) throw new TypeError("getPopularTags: db is required");
+  if (!Number.isFinite(limit) || limit < 1) limit = 10;
+  const stmt = db.prepare(
+    "SELECT tag, COUNT(*) as count FROM memory_tags GROUP BY tag ORDER BY count DESC LIMIT ?"
+  );
+  return stmt.all(limit) as PopularTag[];
+}
+
+export function searchByTag(
+  db: UnifiedDB,
+  tag: string,
+  keyword: string,
+  limit: number
+): TagSearchResult[] {
+  if (!db) throw new TypeError("searchByTag: db is required");
+  if (typeof tag !== "string") throw new TypeError("searchByTag: tag must be a string");
+  if (!Number.isFinite(limit) || limit < 1) limit = 10;
+  if (keyword) {
+    const stmt = db.prepare(
+      "SELECT t.memory_id, t.tag, m.user_text, m.asst_text, m.date " +
+      "FROM memory_tags t " +
+      "JOIN memory_meta m ON t.memory_id = m.id " +
+      "WHERE t.tag = ? AND (m.user_text LIKE ? OR m.asst_text LIKE ?) " +
+      "ORDER BY m.date DESC LIMIT ?"
+    );
+    const likeQ = `%${keyword}%`;
+    return stmt.all(tag, likeQ, likeQ, limit) as TagSearchResult[];
+  }
+  const stmt = db.prepare(
+    "SELECT t.memory_id, t.tag, m.user_text, m.asst_text, m.date " +
+    "FROM memory_tags t " +
+    "JOIN memory_meta m ON t.memory_id = m.id " +
+    "WHERE t.tag = ? " +
+    "ORDER BY m.date DESC LIMIT ?"
+  );
+  return stmt.all(tag, limit) as TagSearchResult[];
+}
