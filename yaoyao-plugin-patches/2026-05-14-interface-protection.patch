+++ b/src/platform/db/compat.ts
@@ -0,0 +1,66 @@
+/**
+ * platform/db/compat.ts — Automatic database backend selection.
+ *
+ * Tries (in order):
+ *   1. node:sqlite      — Node 22+ built-in
+ *   2. better-sqlite3   — npm package (Node 18/20)
+ *   3. file-db          — pure filesystem fallback
+ *
+ * All callers use UnifiedDB from ./types.ts
+ */
+
+import type { PluginLogger } from "openclaw/plugin-sdk/plugin-entry";
+import type { DBCompatResult, DBBackend } from "./types.js";
+import { createNativeDB, isNativeAvailable } from "./native.js";
+import { createNpmDB, isNpmAvailable } from "./npm.js";
+import { createFileDB } from "./file.js";
+
+export type { UnifiedDB, UnifiedStatement, DBCompatResult, DBBackend } from "./types.js";
+
+export function createCompatDB(
+  dbPath: string,
+  config?: { allowExtension?: boolean },
+  logger?: PluginLogger
+): DBCompatResult {
+  if (isNativeAvailable()) {
+    logger?.info?.("[yaoyao-memory:db] Using node:sqlite (Node 22+)");
+    return {
+      db: createNativeDB(dbPath, config?.allowExtension ?? true),
+      backend: "node-sqlite",
+      supportsFTS5: true,
+      supportsWAL: true,
+      supportsExtensions: true,
+    };
+  }
+
+  if (isNpmAvailable()) {
+    logger?.info?.("[yaoyao-memory:db] Using better-sqlite3 (npm)");
+    return {
+      db: createNpmDB(dbPath),
+      backend: "better-sqlite3",
+      supportsFTS5: true,
+      supportsWAL: true,
+      supportsExtensions: false,
+    };
+  }
+
+  logger?.warn?.("[yaoyao-memory:db] No SQLite available, falling back to file-db");
+  return {
+    db: createFileDB(dbPath),
+    backend: "file-db",
+    supportsFTS5: false,
+    supportsWAL: false,
+    supportsExtensions: false,
+  };
+}
+
+export function getDBCapability(): {
+  backend: DBBackend | "unknown";
+  nodeSqliteAvailable: boolean;
+  betterSqlite3Available: boolean;
+} {
+  const node = isNativeAvailable();
+  const npm = isNpmAvailable();
+  const backend: DBBackend | "unknown" = node ? "node-sqlite" : npm ? "better-sqlite3" : "unknown";
+  return { backend, nodeSqliteAvailable: node, betterSqlite3Available: npm };
+}
