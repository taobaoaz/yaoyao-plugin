+        edgeLimitMax: clampNum(params.edgeLimitMax, 400, 1, 2000),
+      };
+
+      const ftsLimit = Math.min(20, 5 + depth * 5);
+      const initialResults = db.search(query, ftsLimit);
+      const memFilenameMap = buildFilenameToIdMap(db);
+
+      const graph = buildGraph(
+        query,
+        initialResults,
+        scenes,
+        tags,
+        memFilenameMap,
+        weights,
+      );
+
+      if (format === "json") {
