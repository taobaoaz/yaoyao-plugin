{
  "name": "@yaoyao/yaoyao-memory-plugin",
  "version": "1.2.0",
  "description": "Yaoyao Memory — 搭载摇摇记忆引擎的四层记忆系统。FTS5 + sqlite-vec 混合搜索、情感分析、时间线、一键备份。让 AI 拥有长时记忆。",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "yaoyao",
    "memory-system",
    "fts5",
    "vector-search",
    "semantic-search"
  ],
  "homepage": "https://github.com/taobaoaz/yaoyao-plugin#readme",
  "author": "Yaoyao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taobaoaz/yaoyao-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/taobaoaz/yaoyao-plugin/issues"
  },
  "engines": {
    "node": "^22.0.0"
  },
  "private": false,
  "scripts": {
    "test": "node --experimental-strip-types --test src/__tests__/*.test.ts",
    "test:db": "node --experimental-strip-types --test src/__tests__/db-bridge.test.ts",
    "test:sentiment": "node --experimental-strip-types --test src/__tests__/sentiment.test.ts",
    "test:store": "node --experimental-strip-types --test src/__tests__/memory-store.test.ts",
    "test:parse": "node --experimental-strip-types --test src/__tests__/llm-parse.test.ts",
    "test:filter": "node --experimental-strip-types --test src/__tests__/session-filter.test.ts",
    "benchmark": "node --experimental-strip-types --test src/__tests__/benchmark.test.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
