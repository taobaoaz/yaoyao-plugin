{
  "id": "yaoyao-memory",
  "name": "Yaoyao Memory",
  "description": "四层记忆系统 (FTS5 + sqlite-vec 向量搜索 + 可选 LLM 管线) — 自动捕获对话, 混合搜索, 情感分析心情环, 记忆时间线, 场景管理, 用户画像生成。搭载「摇摇·记忆」引擎，让你的 AI 拥有长时记忆。",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "capture": {
        "type": "object",
        "description": "对话自动捕获设置 (L0)",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用自动对话捕获"
          }
        }
      },
      "recall": {
        "type": "object",
        "description": "记忆自动召回设置",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用自动记忆召回"
          },
          "maxResults": {
            "type": "number",
            "default": 3,
            "description": "召回最大结果数"
          }
        }
      },
      "memoryDir": {
        "type": "string",
        "default": "",
        "description": "自定义记忆目录路径（默认：~/.openclaw/workspace/memory/）"
      },
      "embedding": {
        "type": "object",
        "description": "向量嵌入配置（可选，开启后支持向量+混合搜索）",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "是否启用向量嵌入"
          },
          "provider": {
            "type": "string",
            "default": "openai",
            "description": "嵌入 API provider"
          },
          "baseUrl": {
            "type": "string",
            "default": "",
            "description": "嵌入 API base URL"
          },
          "apiKey": {
            "type": "string",
            "default": "",
            "description": "嵌入 API key"
          },
          "model": {
            "type": "string",
            "default": "",
            "description": "嵌入模型名称"
          },
          "dimensions": {
            "type": "number",
            "default": 1024,
            "description": "向量维度"
          }
        }
      },
      "llm": {
        "type": "object",
        "description": "LLM 配置（可选，开启后支持 L1/L2/L3 管线）。如未配置但已启用 embedding，将自动复用 embedding 的 apiKey/baseUrl。设置 enabled: false 可强制关闭",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用 LLM 管线（设为 false 可强行关闭）"
          },
          "apiKey": {
            "type": "string",
            "default": "",
            "description": "LLM API key（留空则自动检测 embedding 配置）"
          },
          "baseUrl": {
            "type": "string",
            "default": "https://api.deepseek.com",
            "description": "LLM API base URL（留空则自动检测 embedding 配置）"
          },
          "model": {
            "type": "string",
            "default": "deepseek-chat",
            "description": "LLM 模型名称（留空则根据 baseUrl 自动选择：Gitee→Qwen3-8B，DeepSeek→deepseek-chat，OpenAI→gpt-4o-mini）"
          }
        }
      },
      "cleanup": {
        "type": "object",
        "description": "记忆清理配置（可选）",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用每日清理"
          },
          "l0l1RetentionDays": {
            "type": "number",
            "default": 30,
            "description": "每日日志保留天数（0=不清理，默认30天）"
          },
          "allowAggressiveCleanup": {
            "type": "boolean",
            "default": false,
            "description": "是否允许激进清理（retentionDays=1或2）"
          }
        }
      },
      "blockLabels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "排除的 session label 列表，匹配的 session 不会被捕获/召回"
      },
      "autoSaveImage": {
        "type": "boolean",
        "default": false,
        "description": "启用后，AI 在收到图片并理解其内容后会自动调用 memory_save 将图片描述存入记忆"
      },
      "cloud": {
        "type": "object",
        "description": "云备份同步配置（凭证存储在 ~/.openclaw/credentials/secrets.env）",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用云备份功能"
          },
          "autoSync": {
            "type": "boolean",
            "default": false,
            "description": "是否启用每日自动同步（上传）"
          },
          "conflictPolicy": {
            "type": "string",
            "default": "newer",
            "description": "双向同步冲突策略: newer=保留更新的文件, keep_both=保留双方",
            "enum": ["newer", "keep_both"]
          },
          "excludePatterns": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "排除同步的文件名模式（如 [\"*.log\", \".tmp\"]）"
          }
        }
      }
    }
  },
  "supersedes": [
    "yaoyao-memory",
    "yaoyao-memory-v2"
  ],
  "migration": {
    "from": "yaoyao-memory",
    "version": "1.x",
    "instructions": "自动迁移：插件启动时将清理旧 skill 目录，所有功能由插件接管。无需手动操作。"
  }
}
